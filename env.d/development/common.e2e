FRONTEND_RELEASE_NOTE_ENABLED=False
FRONTEND_HELP_MENU_CONFIG={"documentationUrl": "https://docs.numerique.gouv.fr/docs/87938a46-6f85-4a08-9043-62d1d7d43176/", "legal": {"personalDataUrl": "https://docs.numerique.gouv.fr/docs/1b2c0c97-5141-4a4a-a98d-2a57802f5e72/", "termsOfUseUrl": "https://docs.numerique.gouv.fr/docs/637b1d6a-3b22-4195-b3a2-d88c42e48133/", "accessibilityUrl": "https://docs.numerique.gouv.fr/docs/96653d0c-c9e0-49e3-b98d-d19d5613506a/", "legalNoticeUrl": "https://docs.numerique.gouv.fr/docs/96653d0c-c9e0-49e3-b98d-d19d5613506a/"}, "supportEmail": "mailto:support@numerique.gouv.fr"}

# Deterministic E2E mounts: provide a local filesystem-backed mount so the
# MountProvider E2E spec can run without an SMB server.
MOUNTS_REGISTRY_FILE=/app/e2e/fixtures/mounts_registry.e2e.json

# OIDC (E2E from-scratch on the Compose network)
# Use the Docker service hostname for the authorization endpoint so Keycloak issues
# tokens with an issuer that matches the backend's backchannel calls (`http://nginx:8083/...`).
OIDC_OP_AUTHORIZATION_ENDPOINT=http://nginx:8083/realms/drive/protocol/openid-connect/auth
OIDC_OP_URL=http://nginx:8083/realms/drive
OIDC_OP_JWKS_ENDPOINT=http://nginx:8083/realms/drive/protocol/openid-connect/certs
OIDC_OP_TOKEN_ENDPOINT=http://nginx:8083/realms/drive/protocol/openid-connect/token
OIDC_OP_USER_ENDPOINT=http://nginx:8083/realms/drive/protocol/openid-connect/userinfo
OIDC_OP_LOGOUT_ENDPOINT=http://nginx:8083/realms/drive/protocol/openid-connect/logout
OIDC_OP_INTROSPECTION_ENDPOINT=http://nginx:8083/realms/drive/protocol/openid-connect/token/introspect
OIDC_REDIRECT_ALLOWED_HOSTS="http://127.0.0.1:3000,http://127.0.0.1:8071,http://localhost:8083,http://localhost:3000"
LOGIN_REDIRECT_URL=http://127.0.0.1:3000
LOGIN_REDIRECT_URL_FAILURE=http://127.0.0.1:3000
LOGOUT_REDIRECT_URL=http://127.0.0.1:3000

# Optional (dev/E2E): enable authenticated calls to `/api/v1.0/e2e/*` from Playwright.
# Do not commit real tokens; set these in the environment or in a gitignored env file.
DJANGO_SERVER_TO_SERVER_API_TOKENS=
E2E_S2S_TOKEN=

WOPI_CLIENTS=collabora
